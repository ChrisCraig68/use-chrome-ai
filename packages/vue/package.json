{
  "name": "@use-chrome-ai/vue",
  "version": "0.1.4",
  "description": "Vue composables for the built-in AI APIs in Chrome and Edge, built on use-chrome-ai. Headless — bring your own UI.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ChrisCraig68/use-chrome-ai",
    "directory": "packages/vue"
  },
  "bugs": {
    "url": "https://github.com/ChrisCraig68/use-chrome-ai/issues"
  },
  "homepage": "https://github.com/ChrisCraig68/use-chrome-ai#readme",
  "type": "module",
  "sideEffects": false,
  "keywords": [
    "chrome",
    "edge",
    "ai",
    "gemini-nano",
    "built-in-ai",
    "vue",
    "composables",
    "on-device",
    "llm"
  ],
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "use-chrome-ai": "workspace:*"
  },
  "peerDependencies": {
    "vue": ">=3"
  },
  "devDependencies": {
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "vue": "^3.5.0"
  },
  "engines": {
    "node": ">=18"
  }
}
