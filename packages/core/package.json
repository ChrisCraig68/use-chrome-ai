{
  "name": "use-chrome-ai",
  "version": "0.1.2",
  "description": "Headless, framework-agnostic primitives for the browsers' built-in AI APIs in Chrome and Edge (Prompt, Summarizer, Writer, Rewriter, Proofreader, Translator, Language Detector). Zero dependencies.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ChrisCraig68/use-chrome-ai",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/ChrisCraig68/use-chrome-ai/issues"
  },
  "homepage": "https://github.com/ChrisCraig68/use-chrome-ai#readme",
  "type": "module",
  "sideEffects": false,
  "keywords": [
    "chrome",
    "edge",
    "ai",
    "gemini-nano",
    "built-in-ai",
    "prompt-api",
    "on-device",
    "llm",
    "summarizer",
    "translator"
  ],
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/dom-chromium-ai": "^0.0.7",
    "happy-dom": "^16.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=18"
  }
}
